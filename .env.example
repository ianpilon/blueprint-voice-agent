# Required for end-of-call spec generation. Without it, calls still work and
# transcripts are saved, but no spec-<caller>.md is produced.
OPENAI_API_KEY=

# Optional: model used to write the spec. Defaults to gpt-4o.
# SPEC_MODEL=gpt-4o

# Optional: Postgres connection string. When set, memory + specs persist in
# Postgres (durable on Render/Fly). When unset, memory is a local JSON file
# and specs are written to the specs/ folder.
# DATABASE_URL=

# Optional: server port. Defaults to 3000.
# PORT=3000
